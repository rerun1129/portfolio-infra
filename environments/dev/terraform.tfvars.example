# ================================================================
# мғҲ н”„лЎңм қнҠё мӢңмһ‘ мӢң мқҙ нҢҢмқјмқ„ terraform.tfvarsлЎң ліөмӮ¬ нӣ„ мҲҳм •
# ================================================================

# кіөнҶө
aws_region   = "ap-northeast-2"
iam_role_arn = "arn:aws:iam::740636428516:role/portfolio-terraform-role"

# н”„лЎңм қнҠё (л°ҳл“ңмӢң мҲҳм •)
project_name = "<н”„лЎңм қнҠёлӘ…>"          # мҳҲ: myblog, portfolio, shop
vpc_id       = "vpc-0b5ea269fea455d52" # кі„м • default VPC (лҸҷмқј кі„м •мқҙл©ҙ к·ёлҢҖлЎң мӮ¬мҡ©)

# EC2 (л°ҳл“ңмӢң мҲҳм •)
ec2_key_name     = "<н”„лЎңм қнҠёлӘ…>-ec2-key" # AWS мҪҳмҶ”м—җм„ң мғқм„ұн•ң нӮӨ нҺҳм–ҙ мқҙлҰ„
ssh_allowed_cidr = "<лӮҙ IP>/32"           # мҳҲ: 1.2.3.4/32 (нҷ•мқё: https://ifconfig.me)

# EC2 (м„ нғқ мҲҳм • - кё°ліёк°’ к·ёлҢҖлЎң мҚЁлҸ„ лҗЁ)
ec2_ami           = "ami-0ada8527e6dc686a3" # Amazon Linux 2023 (м„ңмҡё)
ec2_instance_type = "t3.micro"
app_port          = 8080

# S3 (л°ҳл“ңмӢң мҲҳм •)
s3_bucket_name = "<лІ„нӮ·лӘ…>"  # CloudFront S3 originмңјлЎң мӮ¬мҡ©н•  лІ„нӮ· мқҙлҰ„

# RDS (м„ нғқ мҲҳм • - кё°ліёк°’ к·ёлҢҖлЎң мҚЁлҸ„ лҗЁ)
db_instance_class     = "db.t3.micro"
db_engine_version     = "18.3"
rds_security_group_id = "sg-0df35a4a18482821d" # кі„м • default VPC ліҙм•Ҳ к·ёлЈ№

# db_passwordлҠ” нҷҳкІҪліҖмҲҳлЎң м „лӢ¬ (нҢҢмқјм—җ кё°лЎқн•ҳм§Җ л§җ кІғ)
# export TF_VAR_db_password="нҢЁмҠӨмӣҢл“ң"
